---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'UNDERCURRENTは、日本の山・林業・木材と都市生活の繋がりを発見するメディアです。' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="color-scheme" content="light">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title} — UNDERCURRENT</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      color-scheme: light;
      --wide:       1080px;
      --header-h:   64px;
      --ink:        #1A1A18;
      --ink-mid:    #2A2A28;
      --ink-light:  #5A5A56;
      --ink-faint:  #8A8A86;
      --paper:      #F8F7F4;
      --paper-mid:  #EFEFEB;
      --paper-dark: #E2E0DA;
      --white:      #FFFFFF;
      --font:       'Noto Sans JP', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; -webkit-font-smoothing: antialiased; background-color: #F8F7F4; color-scheme: light; }
    a { text-decoration: none; color: inherit; }
    body { background-color: #F8F7F4 !important; color: #1A1A18; font-family: var(--font); font-weight: 300; line-height: 1.9; padding-top: var(--header-h); }

    /* HEADER */
    .site-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: var(--header-h);
      background: #F8F7F4;
      border-bottom: 0.5px solid var(--paper-dark);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem;
    }
    .site-logo img { height: 36px; width: auto; display: block; }
    .hamburger {
      width: 36px; height: 36px;
      display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 5px;
      cursor: pointer; background: none; border: none; padding: 4px;
    }
    .hamburger span {
      display: block; width: 22px; height: 1px; background: var(--ink);
      transition: transform 0.3s, opacity 0.3s; transform-origin: center;
    }
    .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

    /* DRAWER */
    .nav-overlay {
      position: fixed; inset: 0;
      background: rgba(10,10,8,0.3);
      z-index: 98; opacity: 0; pointer-events: none; transition: opacity 0.35s;
    }
    .nav-overlay.open { opacity: 1; pointer-events: all; }
    .nav-drawer {
      position: fixed; top: var(--header-h); right: 0;
      width: 260px; height: calc(100vh - var(--header-h));
      background: #F8F7F4; border-left: 0.5px solid var(--paper-dark);
      transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
      z-index: 99; padding: 2rem 0;
    }
    .nav-drawer.open { transform: translateX(0); }
    .nav-drawer ul { list-style: none; padding: 0 2rem; }
    .nav-drawer li { border-bottom: 0.5px solid var(--paper-dark); }
    .nav-drawer li:first-child { border-top: 0.5px solid var(--paper-dark); }
    .nav-drawer a { display: block; padding: 1rem 0; font-size: 13px; letter-spacing: 0.1em; color: var(--ink-mid); transition: color 0.2s; }
    .nav-drawer a:hover { color: var(--ink); }

    /* FOOTER */
    .site-footer {
      border-top: 0.5px solid var(--paper-dark);
      padding: 2.5rem;
      display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    }
    .footer-logo img { height: 28px; width: auto; opacity: 0.5; }
    .footer-copy { font-size: 11px; color: var(--ink-faint); letter-spacing: 0.06em; }

    /* FADE */
    .fade-in { opacity: 0; transform: translateY(12px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 600px) {
      .site-footer { padding: 1.75rem 1.25rem; flex-direction: column; align-items: flex-start; }
    }

    /* ===== TOP PAGE ===== */
    /* HERO */
    .hero { position: relative; width: 100%; height: 100vh; min-height: 600px; overflow: hidden; display: flex; align-items: flex-end; margin-top: calc(-1 * var(--header-h)); }
    .hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,10,8,0.88) 0%, rgba(10,10,8,0.45) 45%, rgba(10,10,8,0.08) 100%); }
    .hero-content { position: relative; z-index: 2; width: 100%; max-width: var(--wide); margin: 0 auto; padding: 0 1rem 5rem; }
    .hero-eyebrow { font-size: 10px; font-weight: 400; letter-spacing: 0.2em; color: rgba(255,255,255,0.5); text-transform: uppercase; margin-bottom: 1.25rem; padding-left: 0.25rem; }
    .htag { font-size: 10px; font-weight: 400; letter-spacing: 0.12em; padding: 3px 10px; border-radius: 2px; }
    .htag-entry { background: transparent; border: 0.5px solid rgba(255,255,255,0.4); color: rgba(255,255,255,0.85); }
    .htag-issue { background: rgba(255,255,255,0.12); border: 0.5px solid rgba(255,255,255,0.25); color: rgba(255,255,255,0.65); }
    .hero-title { font-size: clamp(28px,4.5vw,56px); font-weight: 400; line-height: 1.35; color: #fff; letter-spacing: 0.03em; margin-bottom: 1.25rem; max-width: 720px; }
    .hero-lead { font-size: 15px; font-weight: 300; color: rgba(255,255,255,0.65); line-height: 1.85; max-width: 520px; letter-spacing: 0.02em; margin-bottom: 2rem; }
    .hero-bottom { display: flex; align-items: flex-end; justify-content: space-between; max-width: 520px; gap: 1rem; }
    .hero-tags { display: flex; gap: 8px; flex-wrap: wrap; }
    .hero-read-more { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 400; letter-spacing: 0.12em; color: rgba(255,255,255,0.7); border-bottom: 0.5px solid rgba(255,255,255,0.3); padding-bottom: 2px; transition: color 0.2s, border-color 0.2s; white-space: nowrap; }
    .hero-read-more:hover { color: #fff; border-color: rgba(255,255,255,0.7); }
    .hero-arrow { display: inline-block; width: 20px; height: 1px; background: currentColor; position: relative; transition: width 0.25s; }
    .hero-arrow::after { content: ''; position: absolute; right: 0; top: -3px; width: 6px; height: 6px; border-top: 1px solid currentColor; border-right: 1px solid currentColor; transform: rotate(45deg); }
    .hero-read-more:hover .hero-arrow { width: 28px; }

    /* SECTION */
    .section { max-width: var(--wide); margin: 0 auto; padding: 4rem 0 2rem; }
    .section-header { display: flex; align-items: baseline; justify-content: space-between; padding: 0 1.25rem 1.5rem; border-bottom: 0.5px solid var(--paper-dark); }
    .section-title { font-size: 11px; font-weight: 400; letter-spacing: 0.18em; color: var(--ink-faint); text-transform: uppercase; }
    .section-link { font-size: 11px; color: var(--ink-faint); letter-spacing: 0.08em; border-bottom: 0.5px solid var(--paper-dark); padding-bottom: 1px; transition: color 0.2s; }
    .section-link:hover { color: var(--ink); }

    /* ARTICLE GRID */
    .article-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 0; }
    .article-card { display: flex; flex-direction: column; cursor: pointer; background: transparent; border-radius: 6px; transition: background 0.2s; padding: 1rem 1rem 0; }
    .article-card:hover { background: var(--paper-mid); }
    .article-card:hover .card-img img { transform: scale(1.03); }
    .card-img { width: 100%; aspect-ratio: 4/3; overflow: hidden; background: var(--paper-dark); margin-bottom: 1rem; }
    .card-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); }
    .card-body { padding: 0 0.25rem 1rem; display: flex; flex-direction: column; flex: 1; }
    .card-title { font-size: 15px; font-weight: 400; color: var(--ink); line-height: 1.65; letter-spacing: 0.03em; margin-bottom: 0.5rem; }
    .card-lead { font-size: 12px; font-weight: 300; color: var(--ink-light); line-height: 1.75; letter-spacing: 0.02em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 0.75rem; }
    .card-meta { display: flex; align-items: flex-end; gap: 6px; flex-wrap: wrap; margin-top: auto; }
    .card-date { font-size: 11px; color: var(--ink-faint); letter-spacing: 0.06em; margin-left: auto; }
    .tsm { font-size: 10px; font-weight: 400; letter-spacing: 0.1em; padding: 2px 8px; border-radius: 2px; }
    .tsm-entry { background: var(--paper-mid); color: var(--ink-light); border: 0.5px solid var(--paper-dark); }
    .tsm-issue { background: var(--ink); color: var(--paper); }

    /* JOB PICKUP */
    .job-pickup { max-width: var(--wide); margin: 0 auto; padding: 4rem 0 2rem; }
    .job-pickup-item { display: grid; grid-template-columns: 200px 1fr; border-bottom: 0.5px solid var(--paper-dark); cursor: pointer; transition: background 0.2s; }
    .job-pickup-item:hover { background: var(--paper-mid); }
    .job-pickup-item:hover .jp-img img { transform: scale(1.03); }
    .jp-img { overflow: hidden; background: var(--paper-dark); aspect-ratio: 4/3; }
    .jp-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); }
    .jp-body { padding: 1.5rem 1.5rem 1.5rem 2rem; display: flex; flex-direction: column; border-left: 0.5px solid var(--paper-dark); }
    .jp-tags { display: flex; gap: 6px; margin-bottom: 0.75rem; }
    .jp-tag { font-size: 10px; font-weight: 400; letter-spacing: 0.1em; padding: 2px 8px; border-radius: 2px; }
    .jp-tag-type { background: var(--ink); color: var(--paper); }
    .jp-tag-area { background: var(--paper-mid); color: var(--ink-light); border: 0.5px solid var(--paper-dark); }
    .jp-org { font-size: 11px; color: var(--ink-faint); letter-spacing: 0.06em; margin-bottom: 4px; }
    .jp-title { font-size: 16px; font-weight: 400; color: var(--ink); line-height: 1.6; letter-spacing: 0.04em; margin-bottom: 0.75rem; }
    .jp-story { font-size: 12px; font-weight: 300; color: var(--ink-light); line-height: 1.8; letter-spacing: 0.02em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: auto; }
    .jp-location { font-size: 11px; color: var(--ink-faint); letter-spacing: 0.06em; margin-top: 1rem; padding-top: 1rem; border-top: 0.5px solid var(--paper-dark); }

    /* PROPERTY PICKUP */
    .prop-pickup { max-width: var(--wide); margin: 0 auto; padding: 4rem 0 2rem; }
    .prop-pickup-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 0; }
    .prop-pickup-card { display: flex; flex-direction: column; cursor: pointer; background: transparent; border-radius: 6px; transition: background 0.2s; padding: 1rem 1rem 0; }
    .prop-pickup-card:hover { background: var(--paper-mid); }
    .prop-pickup-card:hover .pp-img img { transform: scale(1.03); }
    .pp-img { width: 100%; aspect-ratio: 4/3; overflow: hidden; background: var(--paper-dark); margin-bottom: 1rem; }
    .pp-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); }
    .pp-body { padding: 0 0.25rem 1rem; display: flex; flex-direction: column; flex: 1; }
    .pp-tags { display: flex; gap: 6px; margin-bottom: 0.5rem; }
    .pp-tag { font-size: 10px; font-weight: 400; letter-spacing: 0.1em; padding: 2px 8px; border-radius: 2px; }
    .pp-tag-area { background: var(--paper-mid); color: var(--ink-light); border: 0.5px solid var(--paper-dark); }
    .pp-tag-type { background: var(--ink); color: var(--paper); }
    .pp-title { font-size: 14px; font-weight: 400; color: var(--ink); line-height: 1.65; letter-spacing: 0.03em; margin-bottom: 0.5rem; }
    .pp-price { font-size: 15px; font-weight: 400; color: var(--ink); margin-top: auto; padding-top: 0.75rem; }
    .pp-price-note { font-size: 11px; color: var(--ink-faint); margin-left: 6px; }

    /* CATEGORIES NAV */
    .cat-nav { max-width: var(--wide); margin: 0 auto; padding: 4rem 0 6rem; }
    .cat-grid { display: grid; grid-template-columns: repeat(5, minmax(0,1fr)); gap: 0; }
    .cat-item { padding: 2rem 1rem; border-right: 0.5px solid var(--paper-dark); border-bottom: 0.5px solid var(--paper-dark); cursor: pointer; transition: background 0.2s; display: flex; flex-direction: column; gap: 0.5rem; }
    .cat-item:last-child { border-right: none; }
    .cat-item:hover { background: var(--paper-mid); }
    .cat-name { font-size: 16px; font-weight: 400; color: var(--ink); letter-spacing: 0.06em; }
    .cat-desc { font-size: 12px; font-weight: 300; color: var(--ink-faint); line-height: 1.65; letter-spacing: 0.02em; }
    .cat-count { font-size: 11px; color: var(--ink-faint); letter-spacing: 0.06em; margin-top: auto; padding-top: 1rem; }

    @media (max-width: 900px) {
      .article-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
      .prop-pickup-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
      .cat-grid { grid-template-columns: repeat(3, minmax(0,1fr)); }
    }
    @media (max-width: 600px) {
      .hero-content { padding: 0 1.25rem 4rem; }
      .section { padding: 2.5rem 0 1rem; }
      .article-grid { grid-template-columns: 1fr; }
      .job-pickup-item { grid-template-columns: 120px 1fr; }
      .jp-body { padding: 1rem 1rem 1rem 1.25rem; }
      .prop-pickup-grid { grid-template-columns: 1fr; }
      .cat-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
      .cat-item:nth-child(2n) { border-right: none; }
    }
  </style>
</head>
<body>

<header class="site-header">
  <a href="/" class="site-logo">
    <img src="/logo.png" alt="UNDERCURRENT">
  </a>
  <button class="hamburger" id="hamburger" aria-label="メニュー">
    <span></span><span></span><span></span>
  </button>
</header>

<div class="nav-overlay" id="overlay"></div>
<nav class="nav-drawer" id="drawer">
  <ul>
    <li><a href="/category/architecture">建築</a></li>
    <li><a href="/category/product">プロダクト</a></li>
    <li><a href="/category/history">歴史</a></li>
    <li><a href="/category/people">人</a></li>
    <li><a href="/jobs">求人</a></li>
    <li><a href="/properties">空き家</a></li>
    <li><a href="/events">イベント</a></li>
    <li><a href="/about">About</a></li>
  </ul>
</nav>

<slot />

<footer class="site-footer">
  <a href="/" class="footer-logo">
    <img src="/logo.png" alt="UNDERCURRENT">
  </a>
  <span class="footer-copy">© 2024 UNDERCURRENT</span>
</footer>

<script>
  const hamburger = document.getElementById('hamburger');
  const drawer    = document.getElementById('drawer');
  const overlay   = document.getElementById('overlay');
  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    drawer?.classList.toggle('open');
    overlay?.classList.toggle('open');
  });
  overlay?.addEventListener('click', () => {
    hamburger?.classList.remove('open');
    drawer?.classList.remove('open');
    overlay?.classList.remove('open');
  });

  // フェードイン
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });
  document.querySelectorAll('.fade-in').forEach(el => io.observe(el));
</script>

</body>
</html>
